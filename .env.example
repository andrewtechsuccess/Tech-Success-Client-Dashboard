# Environment variables for the Tech Success Client Dashboard.
# In Azure App Service these are set under Settings → Environment variables
# (Application settings). Locally you can copy this to `.env` for reference;
# the server reads them from the process environment.

# ---- Server: Microsoft Entra ID (Microsoft 365) auth ----
# Leave blank to keep the legacy single-password login. Set all three to enable
# Entra SSO. Find these on the Entra app registration's Overview page.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# The "Application ID URI" you set when exposing the API scope, e.g.
# api://clientdash.techsuccess.com.au/<client-id>
ENTRA_APP_ID_URI=

# Set to 1 once Entra is fully live to switch OFF the shared-password login.
DISABLE_PASSWORD_LOGIN=

# Port the server listens on (App Service injects PORT automatically).
PORT=4100

# ---- Client build: Vite (used by the frontend SSO, added in the next step) ----
# These are baked into the built SPA, so set them before `npm run build`.
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
# The API scope the SPA requests, e.g. api://clientdash.techsuccess.com.au/<id>/access_as_user
VITE_ENTRA_API_SCOPE=
